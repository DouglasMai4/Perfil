---
import Sidebar from '../components/Sidebar.astro';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="theme-color" content="#6e44ff">
	</head>
	<body>
		<Sidebar />
		<main>
			<slot />
		</main>
	</body>
</html>

<style lang="sass" is:global>
	@import '../assets/_colors.sass'

	*
		padding: 0
		margin: 0
		box-sizing: border-box
		scroll-behavior: smooth

	::selection
		background-color: $c-primary

	body
		display: grid
		grid-template-columns: 100px 1fr
		grid-template-rows: 100dvh
		gap: 1rem
		font-family: sans-serif
		font-size: 1.2em
		background-color: $bg-color
		color: $c-text
		overflow: hidden

		main
			display: grid
			grid-template-rows: 1fr
			position: relative
			margin: 1rem
			margin-left: 0
			height: 1fr
			border-radius: 1rem
			overflow: hidden
			text-align: center
			box-shadow: 0 0 15px rgba(0, 0, 0, .5)

			.container
				position: sticky
				top: 0
				display: flex
				flex-direction: column
				gap: 1rem
				padding: 1rem
				overflow-y: scroll
				border-radius: 1rem
				grid-row: 1

				section
					background-color: $bg-color
					padding: .5rem
					border-radius: 1rem
					box-shadow: 0 0 15px rgba(0, 0, 0, .5)

			&::before
				content: ''

				position: absolute
				left: -1rem
				width: 55rem
				height: 25rem
				background-color: $c-primary
				z-index: -1
				border-radius: 0 50% 50%
				filter: blur(1rem)

			&::after
				content: ''

				position: absolute
				right: -5rem
				bottom: -7rem
				width: 25rem
				height: 25rem
				background-color: $c-primary
				z-index: -1
				border-radius: 50%
				filter: blur(1rem)

		hr
			border: none
			width: 100%
			height: 2px
			margin-block: 1rem
			background-image: $gradient
			box-shadow: 0 0 10px rgba(0, 0, 0, .5)

		h1
			font-size: 2em

	@media screen and (max-width: 600px)
		body
			grid-template-columns: 1fr
			grid-template-rows: 1fr 100px
			gap: 0

		main
			height: calc(100dvh - 1rem - 100px) !important
			margin-left: 1rem !important
			grid-column: 1
			grid-row: 1

			&::before
				width: 20rem !important

			&:after
				height: 15rem !important
</style>
