---
import { Icon } from 'astro-icon';
---

<nav>
    <ul>
        <li>
            <a href="#sobre">
                <Icon pack="ph" name="user" class="icon" />
                <span>Sobre Mim</span>
            </a>
        </li>
        <li>
            <a href="#conhecimentos">
                <Icon pack="ph" name="books" class="icon" />
                <span>Conhecimentos</span>
            </a>
        </li>
        <li>
            <a href="#portifolio">
                <Icon pack="ph" name="code" class="icon" />
                <span>Portifólio</span>
            </a>
        </li>
        <li>
            <a href="#contato">
                <Icon pack="ph" name="chat-circle-dots" class="icon" />
                <span>Contato</span>
            </a>
        </li>
    </ul>
</nav>

<style lang="sass">
    @import '../assets/_colors.sass'

    nav
        display: grid
        place-items: center
        padding: 1rem
        background-color: $c-primary
        color: $c-text
        border-radius: 1rem
        height: calc(100vh - 2rem)
        width: 100px
        margin: 1rem
        box-shadow: 0 0 5px rgba(0, 0, 0, .3)
        transition: ease-in .2s
        z-index: 999

        ul
            display: flex
            flex-direction: column
            gap: 1rem
            list-style-type: none
            
            li a
                position: relative

                .icon
                    color: $c-text
                    filter: drop-shadow(0 0 2px rgba(0, 0, 0, .5))
                    transition: color .1s ease-in

                &:hover
                    color: $c-second

                    .icon
                        color: $c-second

                    span
                        transform: scaleX(1)
                        // transform-origin: left

                span
                    position: absolute
                    left: 4rem
                    color: $c-text
                    text-decoration: none
                    background-color: $bg-color
                    padding: .5rem
                    font-size: 1.2em
                    text-align: center
                    border-radius: 1rem
                    border: 1px solid $c-second
                    box-shadow: 0 0 5px rgba(0, 0, 0, .3)
                    transform: scaleX(0)
                    transition: transform .3s

        .icon
            width: 3rem
            color: $c-text

    @media screen and (max-width: 600px)
        nav
            position: relative
            height: 100px
            width: calc(100% - 2rem)
            top: none
            bottom: 1rem !important
            grid-column: 1
            grid-row: 2

            ul
                flex-direction: row

                li a
                    span
                        left: -1rem
                        top: -7rem

</style>